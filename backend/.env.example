# Port for the backend server (default: 4000)
PORT=4000

# Allow requests from this frontend origin (default: http://localhost:5173)
FRONTEND_ORIGIN=http://localhost:5173

# ── ThingSpeak (ESP32 live sensor data for Machine Alpha) ─────────────────────
# Channel ID is public — already known from your ESP32 sketch
THINGSPEAK_CHANNEL_ID=3407039

# Read API Key — get this from ThingSpeak → your channel → API Keys tab
# Leave blank to run in full simulator mode
THINGSPEAK_READ_API_KEY=YOUR_READ_API_KEY_HERE

# ── ThingSpeak field mapping (must match what your ESP32 sends) ───────────────
# field1 = avgTemp      (°C)
# field2 = avgVibration (magnitude delta from MPU6050 baseline)
# field3 = equipmentHealth (%)
# NOTE: Your code.c is currently missing ThingSpeak.setField() calls.
# Add these inside runHealthMonitoring() before the closing brace:
#   ThingSpeak.setField(1, avgTemp);
#   ThingSpeak.setField(2, avgVibration);
#   ThingSpeak.setField(3, finalHealth);
#   ThingSpeak.writeFields(channelID, writeAPIKey);
